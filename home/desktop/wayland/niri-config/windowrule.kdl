// 窗口规则配置

// 全局窗口规则：圆角、半透明、背景模糊
// xray 用默认 true → 只模糊壁纸缓存，几乎零开销；不会随下层窗口动态重算
window-rule {
    // 圆角半径
    geometry-corner-radius 12

    // 裁剪到几何形状（避免圆角外的内容溢出）
    clip-to-geometry true

    // 禁止边框画到背景中
    draw-border-with-background false

    // 强制半透明，让 blur 实际可见
    opacity 0.8

    // 静态背景模糊（默认 xray=true，无需显式声明）
    background-effect {
        blur true
    }

    // 弹出菜单也加模糊
    popups {
        geometry-corner-radius 10
        background-effect {
            blur true
        }
    }
}

// ──── 原生透明终端：用动态模糊看真实下层 ────

// Ghostty 终端
window-rule {
    match app-id=r#"^com\.mitchellh\.ghostty$"#
    default-column-width {}

    background-effect {
        blur true
        xray false
    }
}

// Ghostty 浮窗终端（quake 风格，即用即走）
window-rule {
    match app-id=r#"^com\.mitchellh\.ghostty\.quake$"#
    open-floating true

    background-effect {
        blur true
    }
}

// ──── 不透明豁免：内容本身是图像/视频/标注，必须保持原色 ────

window-rule {
    // Firefox / Chrome 画中画
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    match app-id=r#"firefox$"# title="^画中画$"
    match app-id=r#"chrome"# title="^Picture in picture$"
    match app-id=r#"chrome"# title="^画中画$"
    // GNOME 图像查看器
    match app-id="org.gnome.Loupe"
    // Satty 截图标注
    match app-id="com.gabm.satty"
    // mpv / vlc 视频
    match app-id=r#"^mpv$"#
    match app-id=r#"^org\.mpv\.Mpv$"#
    match app-id=r#"^vlc$"#
    // 中文标题的图片/视频窗口
    match title="^图片查看器$"
    match title="^图片和视频$"
    match title="^视频播放器$"

    opacity 1.0
    background-effect {
        blur false
    }
}

// ──── 浏览器画中画浮动 ────

window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    match app-id=r#"firefox$"# title="^画中画$"
    open-floating true
}

window-rule {
    match app-id=r#"chrome"# title="^Picture in picture$"
    match app-id=r#"chrome"# title="^画中画$"
    open-floating true
}

// ──── 国产 IM 软件 ────

// 微信 - 主窗口正常排列，小窗口浮动
window-rule {
    match app-id="wechat" title="^微信$"
    default-column-width { proportion 0.35; }
}

window-rule {
    match app-id="wechat" title=""
    exclude title="^微信$"
    open-floating true
}

// QQ - 主窗口正常排列，辅助窗口浮动
window-rule {
    match app-id=r#"^QQ$"# title="^QQ$"
    default-column-width { proportion 0.35; }
}

window-rule {
    match app-id=r#"^QQ$"# title=""
    exclude title="^QQ$"
    open-floating true
}

// ──── QQ 音乐 ────

window-rule {
    match app-id="qqmusic"
    default-column-width { proportion 0.5; }
}

// ──── 系统工具浮动 ────

window-rule {
    match app-id="nm-connection-editor"
    match app-id="blueman-manager"
    match app-id="org.pulseaudio.pavucontrol"
    match app-id="fcitx" title="Fcitx5 Input Window"
    match app-id="org.gnome.FileRoller"
    match app-id="org.gnome.Calculator"
    match app-id="org.gnome.Loupe"
    match title="^重命名$"
    match title="^图片查看器$"
    match title="^图片和视频$"
    match title="^视频播放器$"
    match title="^日历$"
    match title="^计算器$"
    open-floating true
}

// ──── Steam ────

window-rule {
    match app-id="steam" title="Friends List"
    match title="^Steam 设置$"
    open-floating true
}

// ──── Satty 截图标注 ────

window-rule {
    match app-id="com.gabm.satty"
    open-floating true
}

// ──── 密码管理器安全规则 ────

window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    match app-id=r#"^org\.gnome\.World\.Secrets$"#
    block-out-from "screen-capture"
}

// ──── Telegram ────

window-rule {
    match app-id="org.telegram.desktop" title="^Media viewer$"
    open-floating true
}
